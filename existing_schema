  CONSTRAINT sales_attendance_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.users(id),
  CONSTRAINT sales_attendance_customer_id_fkey FOREIGN KEY (customer_id) REFERENCES public.customer_master(id),
  CONSTRAINT sales_attendance_job_id_fkey FOREIGN KEY (job_id) REFERENCES public.jobs(id)
);
CREATE TABLE public.sales_followups (
