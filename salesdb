create table public.users (
  id integer generated by default as identity not null,
  username character varying(100) null default null::character varying,
  password character varying(255) null default null::character varying,
  role text not null default 'operator'::text,
  is_active boolean null default true,
  full_name character varying(100) null default null::character varying,
  email character varying(150) null default null::character varying,
  phone character varying(20) null default null::character varying,
  last_login timestamp without time zone null,
  created_at timestamp without time zone null default CURRENT_TIMESTAMP,
  constraint users_pkey primary key (id)
) TABLESPACE pg_default;

create table public.sales_attendance (
  id bigint generated by default as identity not null,
  sales_person_id integer not null,
  user_id integer null,
  attendance_date date not null default CURRENT_DATE,
  check_in_at timestamp with time zone not null default now(),
  check_out_at timestamp with time zone null,
  check_in_lat numeric(10, 7) not null,
  check_in_lng numeric(10, 7) not null,
  check_in_accuracy_meters numeric(10, 2) null default null::numeric,
  check_out_lat numeric(10, 7) null default null::numeric,
  check_out_lng numeric(10, 7) null default null::numeric,
  check_out_accuracy_meters numeric(10, 2) null default null::numeric,
  site_name character varying(200) null default null::character varying,
  site_address text null,
  customer_id integer null,
  job_id integer null,
  visit_purpose character varying(200) null default null::character varying,
  notes text null,
  photo_path character varying(300) null default null::character varying,
  status character varying(30) not null default 'present'::character varying,
  approval_status character varying(30) not null default 'pending'::character varying,
  device_info text null,
  ip_address character varying(45) null default null::character varying,
  created_at timestamp with time zone not null default now(),
  updated_at timestamp with time zone not null default now(),
  constraint sales_attendance_pkey primary key (id),
  constraint sales_attendance_customer_id_fkey foreign KEY (customer_id) references customer_master (id),
  constraint sales_attendance_job_id_fkey foreign KEY (job_id) references jobs (id),
  constraint sales_attendance_sales_person_id_fkey foreign KEY (sales_person_id) references sales_persons (id),
  constraint sales_attendance_user_id_fkey foreign KEY (user_id) references users (id)
) TABLESPACE pg_default;

create index IF not exists idx_sales_attendance_sales_person_date on public.sales_attendance using btree (sales_person_id, attendance_date) TABLESPACE pg_default;

create index IF not exists idx_sales_attendance_customer on public.sales_attendance using btree (customer_id) TABLESPACE pg_default;

create index IF not exists idx_sales_attendance_job on public.sales_attendance using btree (job_id) TABLESPACE pg_default;

create unique INDEX IF not exists uq_sales_attendance_one_open_checkin on public.sales_attendance using btree (sales_person_id, attendance_date) TABLESPACE pg_default
where
  (check_out_at is null);


create table public.enquiries (
  id integer generated by default as identity not null,
  enquiry_no character varying(50) null default null::character varying,
  company_id integer null default 1,
  enq_date date null,
  customer_id integer null,
  customer_name character varying(255) null default null::character varying,
  customer_address text null,
  customer_gst character varying(50) null default null::character varying,
  shipper_id integer null,
  shipper character varying(255) null default null::character varying,
  cnee_id integer null,
  cnee character varying(255) null default null::character varying,
  sales_person_id integer null,
  seals_person character varying(255) null default null::character varying,
  mode_id integer null,
  pol_country character varying(255) null default null::character varying,
  pol character varying(255) null default null::character varying,
  pod_country character varying(255) null default null::character varying,
  pod character varying(255) null default null::character varying,
  commodity character varying(255) null default null::character varying,
  packages character varying(50) null default null::character varying,
  packages_unit character varying(50) null default null::character varying,
  gross_weight character varying(50) null default null::character varying,
  gross_weight_unit character varying(50) null default null::character varying,
  cbm character varying(50) null default null::character varying,
  usd_exchange_rate numeric(10, 2) null default 0.00,
  eur_exchange_rate numeric(10, 2) null default 0.00,
  gbp_exchange_rate numeric(10, 2) null default 0.00,
  status character varying(50) null default 'Pending'::character varying,
  cancel_remark text null,
  job_id integer null,
  created_at timestamp without time zone not null default CURRENT_TIMESTAMP,
  updated_at timestamp without time zone not null default CURRENT_TIMESTAMP,
  constraint enquiries_pkey primary key (id),
  constraint fk_enquiries_cnee foreign KEY (cnee_id) references consignee_master (id) on delete set null,
  constraint fk_enquiries_company foreign KEY (company_id) references companies (id) on delete set default,
  constraint fk_enquiries_customer foreign KEY (customer_id) references customer_master (id) on delete set null,
  constraint fk_enquiries_job foreign KEY (job_id) references jobs (id) on delete set null,
  constraint fk_enquiries_mode foreign KEY (mode_id) references mode_master (id) on delete set null,
  constraint fk_enquiries_sales_person foreign KEY (sales_person_id) references sales_persons (id) on delete set null not VALID,
  constraint fk_enquiries_shipper foreign KEY (shipper_id) references shipper_master (id) on delete set null
) TABLESPACE pg_default;

create trigger trg_enquiries_set_updated_at BEFORE
update on enquiries for EACH row
execute FUNCTION set_updated_at ();

create table public.sales_persons (
  id integer generated by default as identity not null,
  name character varying(100) not null,
  email character varying(150) not null,
  mobile character varying(20) null default ''::character varying,
  is_active boolean null default true,
  created_at timestamp without time zone not null default CURRENT_TIMESTAMP,
  user_id integer null,
  designation character varying(100) null default null::character varying,
  department character varying(100) null default null::character varying,
  date_of_joining date null,
  address text null,
  emergency_contact character varying(100) null default null::character varying,
  pan_no character varying(20) null default null::character varying,
  bank_name character varying(100) null default null::character varying,
  bank_account_no character varying(40) null default null::character varying,
  ifsc_code character varying(20) null default null::character varying,
  constraint sales_persons_pkey primary key (id),
  constraint fk_sales_persons_user foreign KEY (user_id) references users (id) on delete set null
) TABLESPACE pg_default;