{
  "expo": {
    "name": "bolt-expo-nativewind",
    "slug": "bonzer-logistics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85a21f86-045e-4076-8965-1f1390af9bef"
      }
    },
    "owner": "brightchild200s-team",
    "android": {
      "package": "com.bonzer.logistics"
    }
  }
}
